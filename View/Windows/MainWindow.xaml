<Window x:Class="RestoApp_Afonichev.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RestoApp_Afonichev"
        mc:Ignorable="d"
        Title="Главное меню" Height="1080" Width="1920">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="100"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>

        <Label Background="#d4d4d4"
               Grid.Row="0"
               Grid.ColumnSpan="3"/>
        <Button Style="{StaticResource MainMenuButton}"
                Grid.Column="2"
                Grid.Row="0"
                HorizontalAlignment="Right"/>
        <Image Grid.Column="1"
               Width="100"
               Height="100"
               Source="O:\Afonichev.Anton\RestoApp_Afonichev\RestoApp_Afonichev\Resources\Icons\logo.png"/>
        <StackPanel>
            <Image Grid.Column="0"
               HorizontalAlignment="Left"
               Width="100"
               Height="100"
               Source="O:\Afonichev.Anton\RestoApp_Afonichev\RestoApp_Afonichev\Resources\Icons\waiter.png"/>

            <TextBlock />
        </StackPanel>
        
    </Grid>
</Window>
